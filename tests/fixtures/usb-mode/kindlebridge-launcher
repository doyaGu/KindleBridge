#!/bin/sh

command=${1:-}
shift || true
test "${1:-}" = --root || exit 2
root=$2
shift 2

if test "$command" = select-staged; then
    test "$#" -eq 0 || exit 2
    test ! -f "$root/run/daemon.pid" || exit 1
    slot=$(cat "$root/next")
    mkdir -p "$root/launcher"
    printf 'test pending slot %s\n' "$slot" >"$root/launcher/pending-slot"
    printf '%s\n' "$slot" >"$root/current"
    rm -f "$root/next"
    printf 'selected staged slot %s\n' "$slot"
    exit 0
fi

test "$command" = run || exit 2
test "${1:-}" = -- || exit 2
shift

slot=$(cat "$root/current")
daemon="$root/slots/$slot/bin/kindlebridged"
mkdir -p "$root/run"

start_child() {
    "$daemon" "$@" &
    child=$!
    rm -f "$root/run/heartbeat"
    if test "${KINDLEBRIDGE_TEST_NO_HEARTBEAT:-0}" != 1; then
        timestamp_ms=$(($(date +%s) * 1000))
        printf 'KINDLEBRIDGE_HEARTBEAT_V1\ninstance=test-%s-%s\ntimestamp_ms=%s\n' \
            "$$" "$child" "$timestamp_ms" \
            >"$root/run/heartbeat"
        rm -f "$root/launcher/pending-slot"
    fi
    printf '%s\n' "$child" >"$root/run/daemon.pid"
}

start_child "$@"
if test "${KINDLEBRIDGE_TEST_SUPERVISOR_RACE:-0}" = 1 ||
    test "${KINDLEBRIDGE_TEST_SUPERVISOR_RESTART:-0}" = 1; then
    crashes=0
    while :; do
        wait "$child" 2>/dev/null || true
        crashes=$((crashes + 1))
        mkdir -p "$root/launcher"
        halted=0
        test "$crashes" -lt 3 || halted=1
        printf 'KINDLEBRIDGE_WATCHDOG_V1\nslot=%s\ncrashes=%s\nnext_start_ms=0\nhalted=%s\n' \
            "$slot" "$crashes" "$halted" >"$root/launcher/watchdog-state"
        test "$halted" = 0 || exit 1
        start_child "$@"
    done
else
    trap 'kill "$child" 2>/dev/null || true; wait "$child" 2>/dev/null || true; exit 0' HUP INT TERM
    wait "$child"
fi
